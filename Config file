servername: ''
port: 443
ssl:
- "SSLEngine on"
- "SSLUseStapling off"
- 'SSLCertificateFile "path"'
- 'SSLCertificateKeyFile "path"'
- 'SSLCertificateChainFile "path"'
- 'Protocols "http/1.1"'
lua_set_env:
OOD_SESSION_COOKIE_SAMESITE: "Lax"
OOD_SESSION_COOKIE_SECURE: "On"
disable_logs: false
logroot: '<logpath>'
errorlog: 'error.log'
accesslog: 'access.log'
logformat: '"%v %h \"%r\" %>s %O \"%{Referer}i\" \"%{User-Agent}i\" %{SSL_PROTOCOL}x %T"'
use_rewrites: true
security_strict_transport: true
proxy_preserve_host: true
auth:
- "AuthType openid-connect"
- "Require valid-user"
oidc_uri: '/oidc'
oidc_provider_metadata_url : "metadataurl"
oidc_client_id : "client-id"
oidc_client_secret : "client-secret"
oidc_redirect_uri: "<redirect-url>"
oidc_remote_user_claim: "preferred_username"
oidc_scope: "openid profile email"
oidc_settings:
OIDCCookiePath : /
OIDCSessionInactivityTimeout : 28800
OIDCSessionMaxDuration : 28800
OIDCPassClaimsAs : environment
OIDCRemoteUserClaim : preferred_username
OIDCStripCookies : <security-cookies>
root_uri: '/pun/sys/dashboard'
public_uri: '/public'
public_root: '/var/www/ood/public'
logout_uri: '/logout'
logout_redirect: '/oidc?logout=<hostname>'
#host_regex: '[^/]+'
nginx_uri: '/nginx'
pun_uri: '/pun'
#oidc_uri: '/oidc'
#host_regex: '.*'
host_regex: '[a-zA-Z0-9.-]+'
node_uri: '/rnode'
rnode_uri: '/rnode'
use_maintenance: false
dex: false
